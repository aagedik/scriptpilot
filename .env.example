# ScriptPilot Environment Example
# Copy this file to `.env.development` or `.env.production` and fill in the values.

# Shopify App Credentials
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SCOPES="read_content,write_content"
SHOPIFY_APP_URL="https://your-app-domain"
SHOP_CUSTOM_DOMAIN=""

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_shadow?schema=public"

# Admin Console Access
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="" # bcrypt hash of the admin password

# Session & Security
SESSION_SECRET="replace-with-strong-random-secret"

# Email Provider (optional)
RESEND_API_KEY=""

# Runtime Ports
PORT=3000
FRONTEND_PORT=8002
HMR_SERVER_PORT=8002
